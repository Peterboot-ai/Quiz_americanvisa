# ==========================================================================
# Quiz America — variáveis de ambiente
# Copie para .env (local) e configure as mesmas no Vercel (Settings > Env Vars)
# NUNCA commitar o .env real (já está no .gitignore)
# ==========================================================================

# --- Supabase (backend / API routes) ---
# Painel Supabase > Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase (frontend / Vite) ---
# Mesmos valores de URL e anon acima, expostos ao browser (seguro expor)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Cron (relatório diário) ---
# Segredo que protege /api/cron/daily-report. Gere um valor aleatório forte.
CRON_SECRET=

# --- Tenant padrão (apenas dev/local) ---
# Slug do tenant usado quando o domínio não resolve (ex.: localhost).
# Em produção o tenant é resolvido pelo domínio.
DEFAULT_TENANT=unlocked

# NOTA: a chave do Brevo NÃO é global — cada tenant tem a sua,
# armazenada no registro do tenant no banco (tabela tenants).
