# Quiz America — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Supabase (backend — nunca expor SERVICE_ROLE_KEY ao frontend)
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (frontend — apenas ANON_KEY)
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# Cron (gere com: openssl rand -hex 32)
CRON_SECRET=

# Tenant padrão (usado em dev local)
DEFAULT_TENANT=unlocked

# URL do site (usado no link de convite de novos parceiros)
SITE_URL=http://localhost:5173
